{
  "schema": "barebone.agent.response.v2",
  "strictJsonObject": true,
  "preferred": true,
  "topLevel": {
    "required": ["schema", "type", "message", "sessionTitle"],
    "schema": "barebone.agent.response.v2",
    "allowedTypes": ["message", "ask_user", "context_request", "action_proposal", "workflow_run_proposal", "plan"],
    "sessionTitlePolicy": "Set sessionTitle on every response. Derive a short, specific German session title from compactState, userPrompt and the conversation focus; max 6 words; avoid generic titles."
  },
  "sessionTitle": {
    "recommended": true,
    "maxWords": 6,
    "policy": "Kurzer Sitzungsname aus komprimiertem Kontext; keine generischen Titel wie Neuer Chat, Allgemeiner Chat, Workflow oder Frage."
  },
  "message": {
    "required": ["type", "message"]
  },
  "actionProposal": {
    "required": ["type", "message", "proposal"],
    "proposalRequired": ["requiresConfirmation", "actions"],
    "actionShape": {
      "required": ["tool", "params"],
      "toolSource": "tools[].name",
      "paramsSource": "tools[].inputSchema"
    },
    "forbiddenTopLevelFields": ["tool", "params", "actions"]
  },
  "workflowRunProposal": {
    "required": ["type", "message", "baseWorkflowId", "workflowUsage", "slotValues", "stepPlan", "actions", "requiresConfirmation"],
    "workflowUsageDecision": ["direct", "adapted", "extended", "deviated", "no_fit"],
    "stepPlanAction": ["use", "override", "skip", "insert"],
    "actionShape": {
      "required": ["tool", "params"],
      "toolSource": "tools[].name",
      "paramsSource": "tools[].inputSchema"
    },
    "policy": "Prefer workflow_run_proposal when workflowCapsules contains a useful workflow. User-facing message must describe only the concrete proposal; workflowUsage.reason is internal."
  },
  "askUser": {
    "required": ["type", "message", "missing"],
    "draftPolicy": "If a draft is included, use draft.proposal with the same proposal shape as action_proposal."
  },
  "contextRequest": {
    "required": ["type", "message", "method", "params"],
    "methodSource": "readOnlyMethods[].name"
  },
  "routeRules": {
    "general_chat": {
      "allowedTypes": ["message"]
    },
    "document_qa": {
      "allowedTypes": ["message", "ask_user"]
    },
    "document_qa_with_cad_context": {
      "allowedTypes": ["message", "ask_user", "context_request"]
    },
    "bricscad_question": {
      "allowedTypes": ["message", "ask_user", "context_request"]
    },
    "bricscad_action": {
      "allowedTypes": ["message", "ask_user", "context_request", "action_proposal", "workflow_run_proposal", "plan"]
    },
    "validation_retry": {
      "allowedTypes": ["message", "ask_user", "context_request", "action_proposal", "workflow_run_proposal", "plan"]
    },
    "execution_summary": {
      "allowedTypes": ["message"]
    }
  },
  "defaultsPolicy": "Ask only for mandatory unknown data. For domain-standard requests, propose sensible defaults and list them in assumptions."
}
