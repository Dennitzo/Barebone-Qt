{
  "schema": "barebone.bricscad.workflow.v1",
  "id": "grundriss_und_aussenwaende_einzeichnen",
  "kind": "bricscad",
  "title": "Grundriss und Außenwände einzeichnen",
  "description": "Erstellt zuerst eine geschlossene Rechteckkontur als freie Hausinnenfläche, prüft deren Fläche und Innenmaße mit aktuellen BRX-Capabilities und zeichnet erst danach vier vollständig außen angrenzende Wandkörper. Ohne Nutzerwerte wird das geprüfte 100-m²-Beispiel mit 10 m × 10 m Innenmaß verwendet.",
  "triggerExamples": [
    "Zeichne einen Grundriss mit Außenwänden.",
    "Erstelle ein Haus mit 100 Quadratmetern Innenfläche.",
    "Nutze den Workflow Grundriss und Außenwände.",
    "Zeichne vier Außenwände um eine Innenfläche."
  ],
  "keywords": [
    "Grundriss",
    "Innenfläche",
    "Außenwände",
    "Haus",
    "100 m²",
    "10 m x 10 m"
  ],
  "preferredTools": [
    "geometry.create",
    "geometry.query",
    "measurement.area",
    "measurement.bbox"
  ],
  "requiredSlots": [],
  "optionalSlots": {
    "roomAreaM2": {
      "type": "number",
      "description": "Gewünschte freie Hausinnenfläche in Quadratmetern."
    },
    "roomWidthMm": {
      "type": "number",
      "description": "Innenbreite in Millimetern."
    },
    "roomLengthMm": {
      "type": "number",
      "description": "Innenlänge in Millimetern."
    },
    "origin": {
      "type": "object",
      "description": "Südwestlicher Ursprung der Innenkontur im WCS."
    },
    "wallThicknessMm": {
      "type": "number",
      "description": "Außenwandstärke in Millimetern."
    },
    "wallHeightMm": {
      "type": "number",
      "description": "Außenwandhöhe in Millimetern."
    },
    "targetLayer": {
      "type": "string",
      "description": "Ziellayer für Kontur und Wandkörper."
    }
  },
  "knownSlotValues": {
    "roomAreaM2": 100,
    "roomWidthMm": 10000,
    "roomLengthMm": 10000,
    "origin": { "x": 0, "y": 0, "z": 0 },
    "wallThicknessMm": 300,
    "wallHeightMm": 2500,
    "targetLayer": "0"
  },
  "valueResolution": {
    "noUserDimensions": "Nutze 100 m² mit 10000 mm Innenbreite und 10000 mm Innenlänge.",
    "areaOnly": "Nutze einen quadratischen Grundriss: Innenbreite = Innenlänge = sqrt(Innenfläche_m² * 1000000).",
    "areaAndOneDimension": "Leite die fehlende Innenabmessung aus Innenfläche_mm² / bekannter Innenabmessung ab.",
    "widthAndLength": "Berechne die Innenfläche aus Innenbreite * Innenlänge / 1000000.",
    "conflict": "Wenn explizite Innenfläche und beide expliziten Innenabmessungen außerhalb der Prüftoleranz widersprüchlich sind, frage gezielt nach, welcher Wert verbindlich ist."
  },
  "derivedValues": [
    {
      "name": "expectedInteriorAreaMm2",
      "expression": "roomWidthMm * roomLengthMm",
      "dependsOn": ["roomWidthMm", "roomLengthMm"],
      "example": 100000000,
      "unit": "mm²"
    },
    {
      "name": "outerWidthMm",
      "expression": "roomWidthMm + 2 * wallThicknessMm",
      "dependsOn": ["roomWidthMm", "wallThicknessMm"],
      "example": 10600,
      "unit": "mm"
    },
    {
      "name": "outerLengthMm",
      "expression": "roomLengthMm + 2 * wallThicknessMm",
      "dependsOn": ["roomLengthMm", "wallThicknessMm"],
      "example": 10600,
      "unit": "mm"
    }
  ],
  "executionBatches": [
    {
      "id": "interior_contour_and_verification",
      "title": "Innenkontur erstellen und prüfen",
      "mode": "sequential",
      "stopOnFailure": true,
      "continueOnlyWhenVerificationPasses": true,
      "steps": [
        {
          "id": "create_interior_contour",
          "title": "Geschlossene Innenkontur erstellen",
          "tool": "geometry.create",
          "paramsTemplate": {
            "geometry": "rectangle",
            "origin": { "x": 0, "y": 0, "z": 0 },
            "width": 10000,
            "depth": 10000,
            "layer": "0",
            "saveBefore": true
          }
        },
        {
          "id": "query_created_contour",
          "title": "Erstellte Rechteckkontur abfragen",
          "tool": "geometry.query",
          "paramsTemplate": {
            "selector": {
              "scope": "lastResult",
              "kind": "polyline",
              "shape": "rectangle"
            },
            "include": ["geometry", "metrics", "dimensions"],
            "limit": 1
          }
        },
        {
          "id": "measure_interior_area",
          "title": "Innenfläche messen",
          "tool": "measurement.area",
          "paramsTemplate": {
            "autoRoomHandlesFromLastQuery": true
          }
        },
        {
          "id": "measure_interior_bounds",
          "title": "Innenabmessungen messen",
          "tool": "measurement.bbox",
          "paramsTemplate": {
            "autoRoomHandlesFromLastQuery": true
          }
        }
      ],
      "verificationContract": {
        "selectorSource": "query_created_contour",
        "requireExactQueryCount": 1,
        "requireClosedRectangle": true,
        "requireAreaMeasuredCount": 1,
        "requireAreaFailedCount": 0,
        "expectedAreaMm2": 100000000,
        "areaToleranceMm2": 10000,
        "requireBBoxMeasuredCount": 1,
        "requireBBoxFailedCount": 0,
        "expectedDimensionsMm": { "widthX": 10000, "depthY": 10000, "heightZ": 0 },
        "expectedBoundsMm": {
          "min": { "x": 0, "y": 0, "z": 0 },
          "max": { "x": 10000, "y": 10000, "z": 0 }
        },
        "dimensionToleranceMm": 1,
        "onFailure": "Stoppe vor Batch exterior_walls und melde die konkrete Soll-Ist-Abweichung.",
        "onSuccess": "Setze mit Batch exterior_walls fort."
      }
    },
    {
      "id": "exterior_walls",
      "title": "Außenwände außerhalb der geprüften Innenkontur erzeugen",
      "mode": "sequential",
      "stopOnFailure": true,
      "dependsOnBatch": "interior_contour_and_verification",
      "requiresVerificationPassed": true,
      "steps": [
        {
          "id": "south_wall",
          "title": "Südliche Außenwand",
          "tool": "geometry.create",
          "paramsTemplate": {
            "geometry": "box",
            "origin": { "x": -300, "y": -300, "z": 0 },
            "width": 10600,
            "depth": 300,
            "height": 2500,
            "layer": "0",
            "saveBefore": false
          }
        },
        {
          "id": "north_wall",
          "title": "Nördliche Außenwand",
          "tool": "geometry.create",
          "paramsTemplate": {
            "geometry": "box",
            "origin": { "x": -300, "y": 10000, "z": 0 },
            "width": 10600,
            "depth": 300,
            "height": 2500,
            "layer": "0",
            "saveBefore": false
          }
        },
        {
          "id": "west_wall",
          "title": "Westliche Außenwand",
          "tool": "geometry.create",
          "paramsTemplate": {
            "geometry": "box",
            "origin": { "x": -300, "y": 0, "z": 0 },
            "width": 300,
            "depth": 10000,
            "height": 2500,
            "layer": "0",
            "saveBefore": false
          }
        },
        {
          "id": "east_wall",
          "title": "Östliche Außenwand",
          "tool": "geometry.create",
          "paramsTemplate": {
            "geometry": "box",
            "origin": { "x": 10000, "y": 0, "z": 0 },
            "width": 300,
            "depth": 10000,
            "height": 2500,
            "layer": "0",
            "saveBefore": false
          }
        }
      ]
    }
  ],
  "constructionStrategy": [
    "Nutzerwerte zuerst nach valueResolution auflösen und sämtliche abgeleiteten Maße neu berechnen.",
    "Nur Batch interior_contour_and_verification vorschlagen, bis dessen BRX-Ergebnisse den verificationContract erfüllen.",
    "Die Messwerkzeuge über den Handle aus query_created_contour binden; keine bestehende Zeichnungsgeometrie mitmessen.",
    "Bei einer Messabweichung keine Wandaktion vorschlagen, sondern die konkrete Abweichung melden.",
    "Nach erfolgreicher Prüfung vier Box-Solids außerhalb der Innenkontur erzeugen; horizontale Wände schließen die Ecken, vertikale Wände liegen dazwischen.",
    "Die Rechteckkontur als sichtbaren Grundriss erhalten und keine BIM-Klassifizierung ergänzen, solange der Nutzer sie nicht verlangt."
  ],
  "forbidden": [
    "Außenwände vor erfolgreicher Flächen- und Maßprüfung erzeugen.",
    "Die angegebene Fläche als äußere Gebäudegrundfläche interpretieren.",
    "Wände nach innen auf die freie Hausinnenfläche setzen.",
    "Eckkörper doppelt überlappen lassen.",
    "Andere als aktuell gemeldete BRX-Capabilities verwenden."
  ],
  "validationExamples": [
    {
      "name": "100-m²-Innenfläche mit außenliegenden Wänden",
      "actions": [
        { "tool": "geometry.create", "params": { "geometry": "rectangle", "origin": { "x": 0, "y": 0, "z": 0 }, "width": 10000, "depth": 10000, "layer": "0", "saveBefore": true } },
        { "tool": "geometry.query", "params": { "selector": { "scope": "lastResult", "kind": "polyline", "shape": "rectangle" }, "include": ["geometry", "metrics", "dimensions"], "limit": 1 } },
        { "tool": "measurement.area", "params": { "autoRoomHandlesFromLastQuery": true } },
        { "tool": "measurement.bbox", "params": { "autoRoomHandlesFromLastQuery": true } },
        { "tool": "geometry.create", "params": { "geometry": "box", "origin": { "x": -300, "y": -300, "z": 0 }, "width": 10600, "depth": 300, "height": 2500, "layer": "0", "saveBefore": false } },
        { "tool": "geometry.create", "params": { "geometry": "box", "origin": { "x": -300, "y": 10000, "z": 0 }, "width": 10600, "depth": 300, "height": 2500, "layer": "0", "saveBefore": false } },
        { "tool": "geometry.create", "params": { "geometry": "box", "origin": { "x": -300, "y": 0, "z": 0 }, "width": 300, "depth": 10000, "height": 2500, "layer": "0", "saveBefore": false } },
        { "tool": "geometry.create", "params": { "geometry": "box", "origin": { "x": 10000, "y": 0, "z": 0 }, "width": 300, "depth": 10000, "height": 2500, "layer": "0", "saveBefore": false } }
      ]
    }
  ],
  "postconditions": [
    "Die sichtbare geschlossene Kontur beschreibt exakt die freie Hausinnenfläche.",
    "Die gemessene Innenfläche beträgt beim Beispiel 100 m² und die Innenabmessungen betragen 10000 × 10000 mm.",
    "Vier Außenwandkörper grenzen mit ihren Innenflächen exakt außen an die Kontur an.",
    "Das Außenmaß des Beispiels beträgt 10600 × 10600 mm.",
    "Die vier Wandkörper überlappen sich an den Ecken nicht."
  ],
  "createdAt": "2026-07-19T00:00:00+02:00",
  "modifiedAt": "2026-07-19T10:00:00+02:00"
}
