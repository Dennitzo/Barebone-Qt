{
    "authoringNotes": {
        "assumptions": [
            "Alle Layer existieren noch nicht oder werden überschrieben, falls sie bereits vorhanden sind."
        ],
        "openQuestions": [],
        "sourcePromptSummary": "Erstelle neue Haus- und TGA-Layer für die Gewerke Heizung, Sanitär, Lüftung und Elektro mit eindeutigen, sinnvollen ACI-Farben."
    },
    "constructionStrategy": [
        "1. Definiere zuerst die Haus-Layer `Haus - Wände`, `Haus - Böden`, `Haus - Türen`, `Haus - Fenster` und `Haus - Dächer` mit eindeutigen ACI-Farbcodes.",
        "2. Ergänze danach die TGA-Layer für Sanitär, Heizung, Lüftung und Elektro mit eindeutigen, gewerktypischen ACI-Farbcodes.",
        "3. Verwende das Tool `layers.ensureMany`, um alle Haus- und TGA-Layer in einem Schritt anzulegen.",
        "4. Der Workflow ist batch‑basiert, damit die Layer sofort im Zeichnungskontext verfügbar sind."
    ],
    "derivedValues": [],
    "description": "Der Workflow legt Haus-Basislayer sowie sämtliche Layer für die Gewerke Heizung, Sanitär, Lüftung und Elektro an. Haus-Layer erhalten neutrale bzw. baunahe Farben; Sanitär ist blau/cyan, Heizung rot/orange, Lüftung grünlich und Elektro gelblich codiert. Jeder Layer erhält einen eindeutigen ACI-Farbcode. Die Layer werden in einem einzigen Batch mit dem Tool `layers.ensureMany` erzeugt.",
    "executionBatches": [
        {
            "id": "create_layers",
            "mode": "sequential",
            "steps": [
                {
                    "id": "step_create_tga_layers",
                    "paramsTemplate": {
                        "layers": "{{tgaLayers}}"
                    },
                    "requiresSlots": [
                        "tgaLayers"
                    ],
                    "title": "Alle Haus- und TGA‑Layer anlegen",
                    "tool": "layers.ensureMany"
                }
            ],
            "stopOnFailure": true,
            "title": "Haus- und TGA‑Layer erstellen"
        }
    ],
    "forbidden": [],
