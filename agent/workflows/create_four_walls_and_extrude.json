{
    "authoringNotes": {
        "assumptions": [
            "Die Innenmaße des Raumes sind exakt 5 000 mm x 4 000 mm.",
            "Alle Wände haben dieselbe Dicke von 240 mm.",
            "Der Raum hat eine Höhe von 3 000 mm.",
            "Die Wandgrundrisse werden auf einem dedizierten Workflow‑Layer erzeugt, damit die Extrusion gezielt auf diese Rechtecke angewendet werden kann.",
            "Die erzeugten 3D‑Solids liegen nach der Extrusion in diesem BricsCAD/BRX‑Stand auf Layer 0 und werden vor der BIM‑Klassifizierung explizit ausgewählt."
        ],
        "openQuestions": [
        ],
        "sourcePromptSummary": "Erstelle einen rechteckigen Raum mit einer lichten Innenfläche von 20 m². Der Raum besitzt die Innenmaße 5 000 mm x 4 000 mm, eine einheitliche Wanddicke von 240 mm und eine Raumhöhe von 3 000 mm. Zeichne dafür vier nicht überlappende, aneinander angrenzende Rechtecke als Wandgrundrisse. Anschließend werden alle vier Rechtecke um 3 000 mm extrudiert und als BIM‑Wände klassifiziert."
    },
    "constructionStrategy": [
        "Berechne die Außenmaße des Wandrings: outerLengthMm = roomLengthMm + 2 * wallThicknessMm und outerWidthMm = roomWidthMm + 2 * wallThicknessMm.",
        "Lege einen dedizierten Layer für die Wandgrundrisse an, damit spätere Selector‑Schritte nicht versehentlich andere Rechtecke in der Zeichnung erfassen.",
        "Erzeuge die Südwand am Ursprung mit Außenlänge und Wanddicke.",
        "Erzeuge die Nordwand bei y = roomWidthMm + wallThicknessMm mit Außenlänge und Wanddicke.",
        "Erzeuge die Westwand zwischen Süd- und Nordwand bei y = wallThicknessMm mit Raum‑Innenbreite und Wanddicke.",
        "Erzeuge die Ostwand bei x = roomLengthMm + wallThicknessMm und y = wallThicknessMm mit Raum‑Innenbreite und Wanddicke.",
        "Extrudiere alle Rechtecke auf dem dedizierten Workflow‑Layer um wallHeightMm.",
        "Wähle die erzeugten 3D‑Solids auf Layer 0 aus.",
        "Klassifiziere die aktuelle Solid-Auswahl als BIMWall."
    ],
    "derivedValues": [
        {
            "dependsOn": [
                "roomLengthMm",
                "wallThicknessMm"
            ],
            "description": "Außenlänge des Wandrings",
            "example": 5480,
            "expression": "roomLengthMm + 2 * wallThicknessMm",
            "name": "outerLengthMm",
            "unit": "mm"
        },
        {
            "dependsOn": [
                "roomWidthMm",
                "wallThicknessMm"
            ],
            "description": "Außenbreite des Wandrings",
            "example": 4480,
            "expression": "roomWidthMm + 2 * wallThicknessMm",
            "name": "outerWidthMm",
            "unit": "mm"
        },
        {
            "dependsOn": [
                "roomWidthMm",
                "wallThicknessMm"
            ],
            "description": "Y‑Position der Nordwand",
            "example": 4240,
            "expression": "roomWidthMm + wallThicknessMm",
            "name": "northWallOriginY",
            "unit": "mm"
        },
        {
            "dependsOn": [
                "roomLengthMm",
                "wallThicknessMm"
            ],
            "description": "X‑Position der Ostwand",
            "example": 5240,
            "expression": "roomLengthMm + wallThicknessMm",
            "name": "eastWallOriginX",
            "unit": "mm"
        }
    ],
    "description": "Erstellt vier nicht überlappende Rechtecke als Wandgrundrisse eines rechteckigen Raumes, extrudiert sie zu 3D‑Wänden und klassifiziert die Resultate als BIM‑Wände.",
    "executionBatches": [
        {
            "id": "prepare_wall_layer",
            "mode": "sequential",
            "steps": [
                {
                    "id": "create_wall_layer",
                    "paramsTemplate": {
                        "name": "{{wallLayerName}}",
                        "saveBefore": true
                    },
                    "requiresSlots": [
                        "wallLayerName"
                    ],
                    "title": "Workflow-Layer für Wandgrundrisse anlegen",
                    "tool": "layers.create"
                }
            ],
            "stopOnFailure": true,
            "title": "Wand‑Layer vorbereiten"
        },
        {
            "id": "create_walls",
            "mode": "sequential",
            "steps": [
                {
                    "id": "south_wall",
                    "paramsTemplate": {
                        "depth": "{{wallThicknessMm}}",
                        "geometry": "rectangle",
                        "layer": "{{wallLayerName}}",
                        "origin": {
                            "x": 0,
                            "y": 0,
                            "z": 0
                        },
                        "saveBefore": false,
                        "width": "{{outerLengthMm}}"
                    },
                    "requiresSlots": [
                        "outerLengthMm",
                        "wallLayerName",
                        "wallThicknessMm"
                    ],
                    "title": "Südwand erstellen",
                    "tool": "geometry.create"
                },
                {
                    "id": "north_wall",
                    "paramsTemplate": {
                        "depth": "{{wallThicknessMm}}",
                        "geometry": "rectangle",
                        "layer": "{{wallLayerName}}",
                        "origin": {
                            "x": 0,
                            "y": "{{northWallOriginY}}",
                            "z": 0
                        },
                        "saveBefore": false,
                        "width": "{{outerLengthMm}}"
                    },
                    "requiresSlots": [
                        "northWallOriginY",
                        "outerLengthMm",
                        "wallLayerName",
                        "wallThicknessMm"
                    ],
                    "title": "Nordwand erstellen",
                    "tool": "geometry.create"
                },
                {
                    "id": "west_wall",
                    "paramsTemplate": {
                        "depth": "{{roomWidthMm}}",
                        "geometry": "rectangle",
                        "layer": "{{wallLayerName}}",
                        "origin": {
                            "x": 0,
                            "y": "{{wallThicknessMm}}",
                            "z": 0
                        },
                        "saveBefore": false,
                        "width": "{{wallThicknessMm}}"
                    },
                    "requiresSlots": [
                        "roomWidthMm",
                        "wallLayerName",
                        "wallThicknessMm"
                    ],
                    "title": "Westwand erstellen",
                    "tool": "geometry.create"
                },
                {
                    "id": "east_wall",
                    "paramsTemplate": {
                        "depth": "{{roomWidthMm}}",
                        "geometry": "rectangle",
                        "layer": "{{wallLayerName}}",
                        "origin": {
                            "x": "{{eastWallOriginX}}",
                            "y": "{{wallThicknessMm}}",
                            "z": 0
                        },
                        "saveBefore": false,
                        "width": "{{wallThicknessMm}}"
                    },
                    "requiresSlots": [
                        "eastWallOriginX",
                        "roomWidthMm",
                        "wallLayerName",
                        "wallThicknessMm"
                    ],
                    "title": "Ostwand erstellen",
                    "tool": "geometry.create"
                }
            ],
            "stopOnFailure": true,
            "title": "Wandgrundrisse erstellen"
        },
        {
            "id": "extrude_and_classify",
            "mode": "sequential",
            "steps": [
                {
                    "id": "extrude_walls",
                    "paramsTemplate": {
                        "detail": "summary",
                        "heightMm": "{{wallHeightMm}}",
                        "saveBefore": false,
                        "selector": {
                            "kind": "rectangle",
                            "layer": "{{wallLayerName}}",
                            "scope": "currentSpace",
                            "shape": "rectangle"
                        }
                    },
                    "requiresSlots": [
                        "wallHeightMm",
                        "wallLayerName"
                    ],
                    "title": "Wände extrudieren",
                    "tool": "rectangles.extrude"
                },
                {
                    "id": "select_extruded_solids",
                    "paramsTemplate": {
                        "selector": {
                            "kind": "solid",
                            "layer": "0",
                            "scope": "currentSpace"
                        }
                    },
                    "requiresSlots": [
                    ],
                    "title": "Extrudierte 3D‑Solids auswählen",
                    "tool": "selection.set"
                },
                {
                    "id": "classify_walls",
                    "paramsTemplate": {
                        "classification": "BIMWall",
                        "saveBefore": false,
                        "target": "selection"
                    },
                    "requiresSlots": [
                    ],
                    "title": "Wände klassifizieren",
                    "tool": "bim.classify"
                }
            ],
            "stopOnFailure": true,
            "title": "Wände extrudieren, auswählen und klassifizieren"
        }
    ],
    "fileName": "create_four_walls_and_extrude.json",
    "forbidden": [
        "rectangles.extrude nicht mit selector.scope=lastResult verwenden, wenn zuvor mehrere Rechtecke erzeugt wurden.",
        "In der Schritt‑für‑Schritt‑Ausführung bim.classify nicht mit target=lastExtruded speichern; nach der Extrusion zuerst die erzeugten Solids auswählen und dann target=selection verwenden.",
        "Nord- und Ostwand nicht auf outerWidthMm/outerLengthMm positionieren; die Ursprungspunkte liegen jeweils eine Wanddicke vor der Außenkante."
