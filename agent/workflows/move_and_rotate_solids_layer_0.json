{
    "authoringNotes": {
        "assumptions": [
            "Alle zu bearbeitenden Solids liegen bereits im Layer 0 und sind geschlossen."
        ]
    },
    "constructionStrategy": [
        "1. Selektiere alle Solids im Layer 0.",
        "2. Verschiebe die Auswahl relativ zum aktuellen Punkt um (1000, 1000, 1000).",
        "3. Rotiere die Auswahl um 45° um ihren eigenen Bounding‑Box‑Mittelpunkt."
    ],
    "derivedValues": [
    ],
    "description": "Wählt alle 3‑D‑Solids im Layer 0, verschiebt sie um (1000 mm, 1000 mm, 1000 mm) relativ zur aktuellen Position und rotiert die Auswahl anschließend um 45° um ihren jeweiligen Bounding‑Box‑Mittelpunkt.",
    "executionBatches": [
        {
            "id": "select_and_move",
            "mode": "sequential",
            "steps": [
                {
                    "id": "step_select_solids",
                    "paramsTemplate": {
                        "selector": {
                            "kind": "solid",
                            "layer": "0",
                            "scope": "currentSpace"
                        }
                    },
                    "title": "Solids im Layer 0 auswählen",
                    "tool": "selection.set"
                },
                {
                    "id": "step_move_solids",
                    "paramsTemplate": {
                        "selector": {
                            "kind": "solid",
                            "layer": "0"
                        },
                        "vector": {
                            "x": 1000,
                            "y": 1000,
                            "z": 1000
                        }
                    },
                    "title": "Auswahl relativ verschieben",
                    "tool": "geometry.move"
                }
            ],
            "stopOnFailure": true,
            "title": "Solids auswählen und verschieben"
        },
        {
            "id": "rotate_solids",
            "mode": "sequential",
            "steps": [
                {
                    "id": "step_rotate_solids",
                    "paramsTemplate": {
                        "angleDeg": 45,
                        "basePointMode": "entityCenter",
                        "selector": {
                            "kind": "solid",
                            "layer": "0"
                        }
                    },
                    "title": "Auswahl um 45° rotieren",
                    "tool": "geometry.rotate"
                }
            ],
            "stopOnFailure": true,
            "title": "Solids rotieren"
        }
    ],
